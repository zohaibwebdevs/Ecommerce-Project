JWT_REFRESH_SECRET=another_secret_key_for_refresh_tokens

# For email (password reset)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# For payments
STRIPE_SECRET_KEY=sk_test_...